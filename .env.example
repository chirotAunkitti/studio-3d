# ---------------------------------------------------------------------------
# Optional environment variables. Copy to ".env.local" and fill in if needed.
# The template works fully without any of these.
# ---------------------------------------------------------------------------

# Connect the contact form to Resend (https://resend.com) to receive emails.
# RESEND_API_KEY=
# CONTACT_TO_EMAIL=you@your-domain.com

# Demo only: shows a "Back to GAT" pill. Leave unset on your own site.
# NEXT_PUBLIC_GAT_SHOWCASE_URL=https://gat-site-seven.vercel.app/#templates
